; GodotOS — project.godot
; This is NOT an editor plugin.
; This project IS the operating system shell.
; Export as a Linux binary, run fullscreen at login.

config_version=5

[application]

config/name="GodotOS"
config/version="0.4.0"
config/description="AI-native graphical operating shell"
run/main_scene="res://boot/shell.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://assets/icon.svg"

[autoload]

; Nothing here — Shell.gd bootstraps all singletons dynamically
; to preserve boot order and allow error handling during init

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3                ; 3 = FULLSCREEN
window/size/borderless=true
window/size/always_on_top=false
window/stretch/mode="viewport"
window/stretch/aspect="expand"
window/vsync/vsync_mode=1

[input]

; Global keyboard shortcuts (processed before any window)
open_terminal={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":true,"meta_pressed":false,"pressed":false,"keycode":84,"physical_keycode":0,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)]
}
open_launcher={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":true,"pressed":false,"keycode":0,"physical_keycode":32,"key_label":0,"unicode":32,"location":0,"echo":false,"script":null)]
}
toggle_ai_console={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":true,"meta_pressed":false,"pressed":false,"keycode":71,"physical_keycode":0,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)]
}
snapshot_save={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":true,"meta_pressed":false,"pressed":false,"keycode":83,"physical_keycode":0,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)]
}

[rendering]

renderer/rendering_method="forward_plus"
environment/defaults/default_clear_color=Color(0.08, 0.08, 0.12, 1)
textures/vram_compression/import_etc2_astc=true

[filesystem]

import/blender/enabled=false

; ────────────────────────────────────────────
; KEYBOARD SHORTCUTS
;   Ctrl+T          → Open Terminal
;   Super+Space     → Open Launcher
;   Ctrl+G          → Toggle AI Console
;   Ctrl+S          → Save Snapshot
; ────────────────────────────────────────────
